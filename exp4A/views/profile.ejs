<!DOCTYPE html>
<html>
<head>
  <title>Student Profile</title>
  <style>
    body {
      font-family: Arial;
      text-align: center;
      margin-top: 50px;
      background-color: #f5f5f5;
    }
    .card {
      background: white;
      padding: 20px;
      width: 300px;
      margin: auto;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.2);
    }
    h1 {
      color: #333;
    }
    p {
      font-size: 18px;
    }
  </style>
</head>
<body>

  <div class="card">
    <h1>Student Profile</h1>

    <p><b>Name:</b> <%= name %></p>
    <p><b>Branch:</b> <%= branch %></p>
    <p><b>Year:</b> <%= year %></p>
  </div>

</body>
</html>